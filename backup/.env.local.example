# Ticket 111: DB backup credentials — copy this file to backup/.env.local
# and fill in the real password. backup/.env.local is gitignored and is
# read by backup/backup-database.ps1; it is never committed.
#
# Get the connection string from:
# Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Use the direct connection (port 5432), not the pooler (6543) — pg_dump
# needs a direct connection.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_HOST:5432/postgres
